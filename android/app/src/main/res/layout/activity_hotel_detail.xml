<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBar"
        android:layout_width="match_parent"
        android:layout_height="300dp"
        android:theme="@style/Theme.AppCompat.NoActionBar">

        <com.google.android.material.appbar.CollapsingToolbarLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            app:contentScrim="?attr/colorPrimary"
            app:layout_scrollFlags="scroll|exitUntilCollapsed">

            <!-- Image Banner with ViewPager2 -->
            <androidx.viewpager2.widget.ViewPager2
                android:id="@+id/viewPagerImages"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                app:layout_collapseMode="parallax"/>

            <com.google.android.material.tabs.TabLayout
                android:id="@+id/tabLayoutImages"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom|center_horizontal"
                android:layout_marginBottom="8dp"
                android:background="@android:color/transparent"
                app:tabIndicatorHeight="0dp"
                app:tabBackground="@android:color/transparent"
                app:tabTextColor="#FFFFFF"
                app:tabSelectedTextColor="#FFFFFF"/>

            <!-- Toolbar已完全移除，不再显示任何内容 -->

        </com.google.android.material.appbar.CollapsingToolbarLayout>
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:id="@+id/tvDetailName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Hotel Name"
                android:textSize="26sp"
                android:textStyle="bold"
                android:textColor="#333"/>
            
            <!-- 评分、点评数、收藏数、收藏按钮 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="12dp"
                android:gravity="center_vertical">
                
                <!-- 评分 -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">
                    <RatingBar
                        android:id="@+id/ratingBar"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:numStars="5"
                        android:rating="4.5"
                        android:stepSize="0.1"
                        android:isIndicator="true"
                        android:scaleX="0.8"
                        android:scaleY="0.8"
                        style="?android:attr/ratingBarStyleSmall"/>
                    <TextView
                        android:id="@+id/tvRatingScore"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="4.5"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="#FF9800"
                        android:layout_marginStart="4dp"/>
                </LinearLayout>
                
                <!-- 分隔线 -->
                <View
                    android:layout_width="1dp"
                    android:layout_height="16dp"
                    android:background="#DDD"
                    android:layout_marginHorizontal="12dp"/>
                
                <!-- 点评数量 -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="点评"
                        android:textSize="14sp"
                        android:textColor="#666"/>
                    <TextView
                        android:id="@+id/tvReviewCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="128"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="#333"
                        android:layout_marginStart="4dp"/>
                </LinearLayout>
                
                <!-- 分隔线 -->
                <View
                    android:layout_width="1dp"
                    android:layout_height="16dp"
                    android:background="#DDD"
                    android:layout_marginHorizontal="12dp"/>
                
                <!-- 收藏数量 -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="收藏"
                        android:textSize="14sp"
                        android:textColor="#666"/>
                    <TextView
                        android:id="@+id/tvFavoriteCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="256"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="#333"
                        android:layout_marginStart="4dp"/>
                </LinearLayout>

                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1"/>

                <!-- 收藏按钮 -->
                <ImageView
                    android:id="@+id/ivFavorite"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:src="@android:drawable/btn_star_big_off"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:padding="4dp"/>
            </LinearLayout>
            
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="8dp">
                 <TextView
                    android:id="@+id/tvDetailStar"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="5 Star"
                    android:textColor="#FF9800"
                    android:background="#FFF3E0"
                    android:padding="4dp"
                    android:textSize="12sp"/>
            </LinearLayout>

            <TextView
                android:id="@+id/tvDetailAddress"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Address..."
                android:layout_marginTop="12dp"
                android:drawableStart="@android:drawable/ic_dialog_map"
                android:drawablePadding="8dp"
                android:textColor="#666"/>
            
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#EEE"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="16dp"/>
                
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="酒店介绍"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#333"/>

            <TextView
                android:id="@+id/tvDetailDesc"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Description..."
                android:layout_marginTop="8dp"
                android:lineSpacingExtra="4dp"
                android:textColor="#555"/>

            <!-- 日历+人间夜选择 -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardCornerRadius="8dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="选择入住日期"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="#333"
                        android:layout_marginBottom="12dp"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:clickable="true"
                            android:focusable="true"
                            android:background="?attr/selectableItemBackground"
                            android:padding="8dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="入住"
                                android:textSize="12sp"
                                android:textColor="#999"/>
                            <TextView
                                android:id="@+id/tvDetailCheckIn"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="01月30日"
                                android:textSize="16sp"
                                android:textStyle="bold"
                                android:textColor="#333"
                                android:layout_marginTop="4dp"/>
                        </LinearLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="→"
                            android:textSize="16sp"
                            android:textColor="#999"
                            android:layout_marginHorizontal="8dp"/>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:clickable="true"
                            android:focusable="true"
                            android:background="?attr/selectableItemBackground"
                            android:padding="8dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="离店"
                                android:textSize="12sp"
                                android:textColor="#999"/>
                            <TextView
                                android:id="@+id/tvDetailCheckOut"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="01月31日"
                                android:textSize="16sp"
                                android:textStyle="bold"
                                android:textColor="#333"
                                android:layout_marginTop="4dp"/>
                        </LinearLayout>

                        <TextView
                            android:id="@+id/tvDetailNights"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="1晚"
                            android:textSize="14sp"
                            android:textColor="#2196F3"
                            android:background="#E3F2FD"
                            android:paddingStart="12dp"
                            android:paddingEnd="12dp"
                            android:paddingTop="8dp"
                            android:paddingBottom="8dp"
                            android:layout_marginStart="8dp"/>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#EEE"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="16dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="房型预订"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#333"/>
            
            <!-- 价格概览卡片 -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardPriceOverview"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                app:cardCornerRadius="8dp"
                app:cardElevation="2dp"
                android:background="#F8F9FA">
                
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp"
                    android:gravity="center_vertical">
                    
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="最低价"
                            android:textSize="12sp"
                            android:textColor="#666"/>
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginTop="4dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="¥"
                                android:textSize="14sp"
                                android:textColor="#2196F3"
                                android:textStyle="bold"/>
                            <TextView
                                android:id="@+id/tvMinPrice"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="299"
                                android:textSize="20sp"
                                android:textStyle="bold"
                                android:textColor="#2196F3"/>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="起"
                                android:textSize="12sp"
                                android:textColor="#999"
                                android:layout_marginStart="2dp"/>
                        </LinearLayout>
                    </LinearLayout>
                    
                    <View
                        android:layout_width="1dp"
                        android:layout_height="40dp"
                        android:background="#E0E0E0"
                        android:layout_marginHorizontal="16dp"/>
                    
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="最高价"
                            android:textSize="12sp"
                            android:textColor="#666"/>
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginTop="4dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="¥"
                                android:textSize="14sp"
                                android:textColor="#FF9800"
                                android:textStyle="bold"/>
                            <TextView
                                android:id="@+id/tvMaxPrice"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="599"
                                android:textSize="20sp"
                                android:textStyle="bold"
                                android:textColor="#FF9800"/>
                        </LinearLayout>
                    </LinearLayout>
                    
                    <View
                        android:layout_width="1dp"
                        android:layout_height="40dp"
                        android:background="#E0E0E0"
                        android:layout_marginHorizontal="16dp"/>
                    
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="可选房型"
                            android:textSize="12sp"
                            android:textColor="#666"/>
                        <TextView
                            android:id="@+id/tvRoomTypeCount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="5种"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:textColor="#333"
                            android:layout_marginTop="4dp"/>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>
                
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvRooms"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:nestedScrollingEnabled="false"/>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#EEE"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="16dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="用户点评"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#333"/>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvReviews"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:nestedScrollingEnabled="false"/>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
